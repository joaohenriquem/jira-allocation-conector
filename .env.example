# =============================================================================
# Jira Allocation Connector - Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# ACCESS CONTROL
# -----------------------------------------------------------------------------

# Comma-separated list of allowed IPs (leave empty to disable IP filtering)
# Example: ALLOWED_IPS=192.168.1.1,10.0.0.1,203.0.113.50
ALLOWED_IPS=

# -----------------------------------------------------------------------------
# JIRA AUTHENTICATION
# -----------------------------------------------------------------------------

# Jira Base URL
JIRA_BASE_URL=https://your-domain.atlassian.net

# Your Atlassian account email
JIRA_USERNAME=your-email@company.com

# API Token (generate at: https://id.atlassian.com/manage-profile/security/api-tokens)
JIRA_API_TOKEN=your-api-token-here

# Personal Access Token (for Jira Server/Data Center only)
JIRA_PERSONAL_ACCESS_TOKEN=

# -----------------------------------------------------------------------------
# MONGODB CACHE CONFIGURATION
# -----------------------------------------------------------------------------

# MongoDB connection URI (Atlas or local)
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/?appName=YourApp

# MongoDB database name for cache
MONGODB_DATABASE=jira_cache

# Enable MongoDB cache (true/false) - falls back to session_state if false
MONGODB_CACHE_ENABLED=true

# -----------------------------------------------------------------------------
# AI ASSISTANT CONFIGURATION (Optional)
# -----------------------------------------------------------------------------

# Enable or disable AI analysis feature (true/false)
AI_ENABLED=false

# OpenAI API Key (get at: https://platform.openai.com/api-keys)
OPENAI_API_KEY=

# Anthropic API Key (get at: https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------------
# PROXY/SSL CONFIGURATION (Optional)
# -----------------------------------------------------------------------------

# Set to "true" to bypass proxy
NO_PROXY=false

# Set to "false" to disable SSL verification (use with caution)
SSL_VERIFY=true
